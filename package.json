{
  "name": "mebs-map-studio",
  "version": "0.4.0",
  "private": true,
  "description": "Visual case formulation for Positive Behaviour Support (MEBS) — desktop app",
  "author": "Jake Spicer",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "icon": "node scripts/make-icon.js",
    "app:dev": "next build && electron .",
    "app:dist": "next build && node scripts/make-icon.js && electron-builder --win portable",
    "app:dist:mac": "next build && node scripts/make-icon.js && electron-builder --mac"
  },
  "build": {
    "appId": "com.jakespicer.mebs-map-studio",
    "productName": "MEBS Map Studio",
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "build/icon.ico",
      "!node_modules/**/*"
    ],
    "win": {
      "target": ["portable"],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "MEBS-Map-Studio-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.medical",
      "artifactName": "MEBS-Map-Studio-${version}.dmg"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
